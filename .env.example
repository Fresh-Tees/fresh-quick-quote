# Vercel Blob storage (required for artwork uploads)
# Create a token at https://vercel.com/dashboard/stores → Blob
BLOB_READ_WRITE_TOKEN=
#
# Optional alias if your Vercel project uses a different variable name.
# If both are set, BLOB_READ_WRITE_TOKEN is preferred.
FRESHBLOB_READ_WRITE_TOKEN=

# Quote emails (required to receive quote submissions)
# Address that should receive quote summaries, e.g. quotes@freshtees.com.au
QUOTE_NOTIFY_EMAIL=

# SMTP settings for sending email (e.g. your transactional provider)
# Example for a typical TLS SMTP setup:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# SMTP_FROM=Fresh Tees Gateway <no-reply@freshtees.com.au>

# Optional: allow iframe embed from Shopify (comma-separated origins, no spaces after commas)
# Example: https://your-store.myshopify.com,https://www.freshtees.com.au
# FRAME_ANCESTORS_URLS=
